// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../prisma/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "sqlite"
}

model Tenant {
  id        String   @id @default(uuid())
  name      String   @unique
  themeName String
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  products      Product[]
  theme         Theme?
  hero          Hero?
  features      Feature[]
  users         User[]
  contactFields contactFields[]
  storeSettings StoreSettings?

  @@index([status])
}

model StoreSettings {
  tenantId          String  @id
  metaTitle         String?
  metaDescription   String?
  phone             String?
  phoneDisplay      String?
  instagram         String?
  whatsappMessage   String?
  footerDescription String?
  footerNotice      String?

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model Product {
  id            String   @id @default(uuid())
  tenantId      String
  name          String
  category      String
  description   String?
  price         Float
  priceOriginal Float?
  badge         String?
  image         String?
  rating        Float?
  reviews       Int?
  stock         Int
  highlight     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  // Indexes
  @@index([tenantId])
}

model Theme {
  id            String @id @default(uuid())
  tenantId      String @unique
  primary       String
  primaryHover  String
  secondary     String
  secondaryDark String
  surface       String
  text          String
  textMuted     String
  border        String
  gradientStart String
  gradientMid   String
  gradientEnd   String

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model Hero {
  tenantId        String  @id
  badge           String?
  titleLine1      String?
  titleLine2      String?
  titleHighlight  String?
  description     String?
  buttonPrimary   String?
  buttonSecondary String?

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model Feature {
  id       Int     @id @default(autoincrement())
  tenantId String
  icon     String?
  label    String?
  title    String?
  colors   Json?

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  // Indexes
  @@index([tenantId])
}

model contactFields {
  tenantId    String
  id          String  @id @unique
  label       String
  type        String
  placeholder String
  required    Boolean

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}
